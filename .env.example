GOOSE_DRIVER=postgres
GOOSE_DBSTRING="postgres://user:pass@localhost:5432/auction_platform"
GOOSE_MIGRATION_DIR=./migrations

# Service Ports
AUTH_PORT=8080
AUCTION_PORT=8081

# Legacy (deprecated, use AUTH_PORT and AUCTION_PORT instead)
PORT=9090

# Authentication
JWT_SECRET="jwt_secret"

# Email (Resend)
RESEND_API_KEY=""
RESEND_EMAIL_FROM=""

# Redis
REDIS_URL="redis://redis:6379"